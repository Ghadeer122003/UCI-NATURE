# secrets — service account key must never be committed
secrets/

# data — large/transient directories
data/staging/
data/staging_full_backup/
data/downloads/
data/tmp/
data/cache/
data/test_runs/
data/staging_all/
data/staging_preprocessed/

# pipeline outputs are transient — ignore everything except sample data
data/outputs/*

# allow small sample data to be committed
!data/sample/
!data/sample/**
!data/sample/images/**
!data/sample/outputs/**

# python
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/

# mac
.DS_Store
.claude/

# envs / venvs
.env
.venv
.venv*/
venv/
.conda/

# notes/screenshots
notes/*.png
*.pem
.env
AGENTS.md
ui/backend/data/logs/
ui/backend/data/session.json
ui/backend/data/sessions/
site/
